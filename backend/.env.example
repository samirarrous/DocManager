# Zammad API Configuration
ZAMMAD_API_URL=http://localhost:8080/api/v1
ZAMMAD_API_TOKEN=your_zammad_api_token_here

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/appdb
DB_USERNAME=your_database_username_here
DB_PASSWORD=your_database_password_here

# AWS Configuration
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
AWS_REGION=your_aws_region_here
AWS_BUCKET_NAME=your_bucket_name_here

# Security Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost
